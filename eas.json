{
    "cli": {
        "version": ">= 16.0.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": false
            }
        },
        "preview": {
            "distribution": "store",
            "autoIncrement": true,
            "env": {
                "APP_VARIANT": "preview",
                "SENTRY_DISABLE_AUTO_UPLOAD": "true"
            }
        },
        "production": {
            "distribution": "store",
            "autoIncrement": true,
            "env": {
                "APP_VARIANT": "production"
            }
        }
    },
    "submit": {
        "preview": {},
        "production": {}
    }
}