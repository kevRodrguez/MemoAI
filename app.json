{
  "expo": {
    "name": "Memo",
    "slug": "Memo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/MemoAppIcon.png",
    "scheme": "memo",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.kevrodrguez.Memo"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/MemoAppIcon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.kevrodrguez.Memo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
